<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="@dimen/padding_sm">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvItemIssue"
        style="@style/CardView"
        android:layout_width="@dimen/width_issue"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin"
        android:backgroundTint="@color/background_light"
        app:cardCornerRadius="@dimen/padding"
        app:contentPaddingBottom="@dimen/padding_sm"
        app:contentPaddingLeft="@dimen/padding"
        app:contentPaddingRight="@dimen/padding"
        app:contentPaddingTop="@dimen/padding_sm">

        <TextView
            android:id="@+id/tvItemIssueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_text"
            android:textSize="@dimen/text_size"
            tools:text="@string/issue" />

        <ImageView
            android:id="@+id/ivItemIssueDoubleArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_double_arrow"
            app:tint="@color/application" />

    </androidx.cardview.widget.CardView>

</LinearLayout>