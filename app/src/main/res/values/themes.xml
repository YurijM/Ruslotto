<resources>
    <!-- Base application theme. -->
    <style name="Theme.Ruslotto" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/application</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <!--<item name="colorSecondary">@color/teal_200</item>-->
        <item name="colorSecondary">@color/color_text</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="SplashActivity" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/background</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="Theme.Ruslotto.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@drawable/background</item>
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textSize">@dimen/text_size</item>
    </style>

    <style name="Theme.Ruslotto.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Ruslotto.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="TableRow" parent="@android:style/TextAppearance.Small">
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">@dimen/text_size</item>
        <item name="android:background">@color/white</item>
        <item name="android:layout_marginEnd">@dimen/margin_sm</item>
        <item name="android:paddingStart">@dimen/margin_sm</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAlignment">center</item>
        <!--<item name="android:layout_height">@dimen/_30sdp</item>-->
    </style>

    <style name="FloatingActionButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:backgroundTint">@color/application</item>
        <item name="android:src">@drawable/ic_add</item>
        <item name="android:layout_gravity">end</item>
        <item name="tint">@color/white</item>
        <item name="maxImageSize">40dp</item>
        <item name="android:layout_margin">@dimen/margin_sm</item>
    </style>

    <style name="ProgressBar">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

</resources>